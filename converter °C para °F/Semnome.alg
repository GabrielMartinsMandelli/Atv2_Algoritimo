algoritmo   "IMC"
// Funçăo :converter Celsius para fahrenheit
// Autor :Gabriel martins
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
n1,n2,n3:real
valorFinal:real
inicio
// Seçăo de Comandos
 escreva ("Digite o graus celsius: ")
 leia(n1)
//calculo
valorFinal <- 9*n1/5+32
   limpatela
   escreva ("O valor do IMC é: ", valorFinal, "!")

fimalgoritmo
